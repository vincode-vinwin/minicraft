  },
  {
    id: "dirt",
    name: "Erde",
    inventoryTexture: textures.dirt,
    materials: Array.from({ length: 6 }, () => new THREE.MeshStandardMaterial({ map: textures.dirt }))
  },
  {
    id: "stone",
    name: "Stein",
    inventoryTexture: textures.stone,
    materials: Array.from({ length: 6 }, () => new THREE.MeshStandardMaterial({ map: textures.stone }))
  },
  {
    id: "sand",
    name: "Sand",
    inventoryTexture: textures.sand,
    materials: Array.from({ length: 6 }, () => new THREE.MeshStandardMaterial({ map: textures.sand }))
  }
];

let selectedBlockIndex = 0;
const inventoryCounts = [8, 6, 12, 6];
const FALL_DAMAGE_SAFE_SPEED = 12;
const FALL_DAMAGE_SCALE = 1.6;
let isCreativeMode = false;

function buildInventory() {
  inventoryElement.innerHTML = "";

  blockTypes.forEach((blockType, index) => {
    const slot = document.createElement("div");
    slot.className = "slot";
    slot.dataset.index = String(index);

    const number = document.createElement("span");
    number.textContent = String(index + 1);
    number.className = "slot-number";

    const icon = document.createElement("img");
    icon.src = blockType.inventoryTexture.image.toDataURL();
    icon.alt = "";

    const count = document.createElement("span");
    count.className = "slot-count";
    count.textContent = String(inventoryCounts[index]);

    slot.append(number, icon, count);
    inventoryElement.appendChild(slot);
  });
}

function updateInventorySelection() {
  [...inventoryElement.children].forEach((slot, index) => {
    slot.classList.toggle("active", index === selectedBlockIndex);
    slot.querySelector(".slot-count").textContent = isCreativeMode ? "inf" : String(inventoryCounts[index]);
  });

  const countLabel = isCreativeMode ? "unendlich" : String(inventoryCounts[selectedBlockIndex]);
  selectedLabelElement.textContent = `Block: ${blockTypes[selectedBlockIndex].name} (${countLabel})`;
}

function updateHearts() {
  heartElements.forEach((heart, index) => {
    const heartValue = (index + 1) * 2;
    heart.classList.remove("empty", "half");

    if (player.isCreative) {
      heart.classList.add("empty");
      return;
    }

    if (player.health >= heartValue) {
      return;
    }

    if (player.health === heartValue - 1) {
      heart.classList.add("half");
      return;
    }

    heart.classList.add("empty");
  });
}

function updateModeLabel() {
  modeLabelElement.textContent = player.isCreative ? "Modus: Kreativ" : "Modus: Ueberleben";
}

function applyDamage(amount) {
  if (player.isCreative || player.isDead || amount <= 0) {
    return;
  }

  player.health = Math.max(0, player.health - amount);
  updateHearts();

  if (player.health <= 0) {
    killPlayer();
  }
}

function createBlock(typeIndex, position) {
  const blockType = blockTypes[typeIndex];
  const cube = new THREE.Mesh(geometry, blockType.materials);
  cube.position.copy(position);
  cube.userData.typeIndex = typeIndex;
  cube.castShadow = true;
  cube.receiveShadow = true;
  scene.add(cube);
  blocks.push(cube);
  return cube;
}

function createDrop(typeIndex, position) {
  const drop = new THREE.Mesh(
    new THREE.BoxGeometry(0.35, 0.35, 0.35),
    blockTypes[typeIndex].materials
  );
  drop.position.copy(position);
  drop.position.y += 0.3;
  drop.userData.typeIndex = typeIndex;
  drop.userData.velocity = new THREE.Vector3(
    (Math.random() - 0.5) * 1.8,
    2.4 + Math.random() * 0.4,
    (Math.random() - 0.5) * 1.8
  );
  scene.add(drop);
  drops.push(drop);
  return drop;
}

for (let x = -10; x < 10; x++) {
  for (let z = -10; z < 10; z++) {
    createBlock(2, new THREE.Vector3(x, -1, z));

    const surfaceType = Math.abs(x + z) % 7 === 0 ? 3 : 0;
    createBlock(surfaceType, new THREE.Vector3(x, 0, z));

    if ((x * x + z * z) % 11 === 0) {
      createBlock(1, new THREE.Vector3(x, 1, z));
    }
  }
}

buildInventory();
updateInventorySelection();

const clock = new THREE.Clock();
const spawnPoint = new THREE.Vector3(0, 3.6, 7);
const player = {
  eyeHeight: 1.6,
  height: 1.8,
  radius: 0.35,
  moveSpeed: 4.5,
  jumpSpeed: 8.8,
  gravity: 20,
  velocity: new THREE.Vector3(),
  onGround: false,
  maxHealth: 10,
  health: 10,
  isDead: false,
  isCreative: false,
  flySpeed: 6,
  verticalSpeed: 0,
  fallStartY: null
};

camera.position.copy(spawnPoint);
updateHearts();
updateModeLabel();

const keys = {};
document.addEventListener("keydown", (event) => {
  keys[event.code] = true;

  if (event.code === "KeyH") {
    player.isCreative = !player.isCreative;
    isCreativeMode = player.isCreative;
    player.velocity.set(0, 0, 0);
    player.verticalSpeed = 0;
    player.onGround = false;
    player.fallStartY = null;
    player.health = player.isCreative ? player.maxHealth : Math.max(1, player.health);
    updateHearts();
    updateInventorySelection();
    updateModeLabel();
  }

  if (event.code === "Space" && player.isCreative) {
    return;
  }

  if (event.code === "Space" && player.onGround) {
    player.velocity.y = player.jumpSpeed;
    player.onGround = false;
    player.fallStartY = camera.position.y;
  }

  if (/^Digit[1-4]$/.test(event.code)) {
    selectedBlockIndex = Number(event.code.replace("Digit", "")) - 1;
    updateInventorySelection();
  }
});

document.addEventListener("keyup", (event) => {
  keys[event.code] = false;
});

const raycaster = new THREE.Raycaster();

function getPlayerBounds(position = camera.position) {
  const feetY = position.y - player.eyeHeight;

  return {
    minX: position.x - player.radius,
    maxX: position.x + player.radius,
    minY: feetY,
    maxY: feetY + player.height,
    minZ: position.z - player.radius,
    maxZ: position.z + player.radius
  };
}

function intersectsBlock(position, block) {
  const bounds = getPlayerBounds(position);
  const half = blockSize / 2;

  return (
    bounds.minX < block.position.x + half &&
    bounds.maxX > block.position.x - half &&
    bounds.minY < block.position.y + half &&
    bounds.maxY > block.position.y - half &&
    bounds.minZ < block.position.z + half &&
    bounds.maxZ > block.position.z - half
  );
}

function collidesAt(position) {
  return blocks.some((block) => intersectsBlock(position, block));
}

function getMoveDirection() {
  const direction = new THREE.Vector3();
  const forward = new THREE.Vector3();
  camera.getWorldDirection(forward);
  forward.y = 0;
  forward.normalize();

  const right = new THREE.Vector3(forward.z, 0, -forward.x);

  if (keys["KeyW"]) direction.add(forward);
  if (keys["KeyS"]) direction.sub(forward);
  if (keys["KeyA"]) direction.add(right);
  if (keys["KeyD"]) direction.sub(right);

  if (direction.lengthSq() > 0) {
    direction.normalize();
  }

  return direction;
}

function movePlayer(delta) {
  if (player.isDead) {
    return;
  }

  const moveDirection = getMoveDirection();
  const horizontalStep = (player.isCreative ? player.flySpeed : player.moveSpeed) * delta;

  if (player.isCreative) {
    const flyPosition = camera.position.clone();
    flyPosition.x += moveDirection.x * horizontalStep;
    flyPosition.z += moveDirection.z * horizontalStep;

    if (keys["Space"]) {
      player.verticalSpeed = player.flySpeed * delta;
    } else if (keys["ShiftLeft"] || keys["ShiftRight"]) {
      player.verticalSpeed = -player.flySpeed * delta;
    } else {
      player.verticalSpeed = 0;
    }

    flyPosition.y += player.verticalSpeed;
    camera.position.copy(flyPosition);
    player.onGround = false;
    return;
  }

  player.velocity.x = moveDirection.x * horizontalStep;
  player.velocity.z = moveDirection.z * horizontalStep;
  player.velocity.y -= player.gravity * delta;

  const nextPosition = camera.position.clone();

  nextPosition.x += player.velocity.x;
  if (!collidesAt(nextPosition)) {
    camera.position.x = nextPosition.x;
  }

  nextPosition.copy(camera.position);
  nextPosition.z += player.velocity.z;
  if (!collidesAt(nextPosition)) {
    camera.position.z = nextPosition.z;
  }

  nextPosition.copy(camera.position);
  nextPosition.y += player.velocity.y * delta;

  if (!collidesAt(nextPosition)) {
    if (player.velocity.y < 0 && player.fallStartY === null) {
      player.fallStartY = camera.position.y;
    }
    camera.position.y = nextPosition.y;
    player.onGround = false;
    return;
  }

  if (player.velocity.y <= 0) {
    player.onGround = true;
    if (player.fallStartY !== null) {
      const impactSpeed = Math.abs(player.velocity.y);
      const damage = Math.max(0, Math.floor((impactSpeed - FALL_DAMAGE_SAFE_SPEED) / FALL_DAMAGE_SCALE));
      applyDamage(damage);
      player.fallStartY = null;
    }
  }

  player.velocity.y = 0;
}

function respawnPlayer() {
  camera.position.copy(spawnPoint);
  player.velocity.set(0, 0, 0);
  player.verticalSpeed = 0;
  player.onGround = false;
  player.fallStartY = null;
  player.health = player.maxHealth;
  player.isDead = false;
  updateHearts();
}

function killPlayer() {
  if (player.isCreative) {
    return;
  }

  if (player.isDead) {
    return;
  }

  player.isDead = true;
  player.health = 0;
  updateHearts();

  window.setTimeout(() => {
    respawnPlayer();
  }, 700);
}

function updateDrops(delta) {
  for (let i = drops.length - 1; i >= 0; i--) {
    const drop = drops[i];
    const velocity = drop.userData.velocity;

    velocity.y -= 14 * delta;
    drop.position.addScaledVector(velocity, delta);
    drop.rotation.x += 2.8 * delta;
    drop.rotation.y += 4.2 * delta;

    if (drop.position.y < 0.18) {
      drop.position.y = 0.18;
      velocity.y = 0;
      velocity.x *= 0.88;
      velocity.z *= 0.88;
    }

    const dx = drop.position.x - camera.position.x;
    const dy = drop.position.y - (camera.position.y - 1.1);
    const dz = drop.position.z - camera.position.z;
    const distance = Math.sqrt(dx * dx + dy * dy + dz * dz);

    if (distance < 1.2) {
      if (!player.isCreative) {
        inventoryCounts[drop.userData.typeIndex] += 1;
      }
      scene.remove(drop);
      drops.splice(i, 1);
      updateInventorySelection();
    }
  }
}

function swingHand() {
  handElement.classList.remove("swing");
  void handElement.offsetWidth;
  handElement.classList.add("swing");
}

document.addEventListener("mousedown", (event) => {
  swingHand();

  raycaster.setFromCamera(new THREE.Vector2(0, 0), camera);
  const intersects = raycaster.intersectObjects(blocks);

  if (intersects.length === 0) {
    return;
  }

  const hit = intersects[0].object;

  if (event.button === 0) {
    if (!player.isCreative) {
      createDrop(hit.userData.typeIndex, hit.position);
    }
    scene.remove(hit);
    blocks.splice(blocks.indexOf(hit), 1);
  }

  if (event.button === 2) {
    if (!player.isCreative && inventoryCounts[selectedBlockIndex] <= 0) {
      return;
    }

    const newPosition = hit.position.clone().add(intersects[0].face.normal);
    const previewBlock = { position: newPosition };

    if (!intersectsBlock(camera.position, previewBlock)) {
      createBlock(selectedBlockIndex, newPosition);
      if (!player.isCreative) {
        inventoryCounts[selectedBlockIndex] -= 1;
      }
      updateInventorySelection();
    }
  }
});

window.addEventListener("contextmenu", (event) => event.preventDefault());
window.addEventListener("resize", () => {
  camera.aspect = window.innerWidth / window.innerHeight;
  camera.updateProjectionMatrix();
  renderer.setSize(window.innerWidth, window.innerHeight);
});

function animate() {
  requestAnimationFrame(animate);
  const delta = Math.min(clock.getDelta(), 0.05);

  movePlayer(delta);
  updateDrops(delta);

  if (!player.isCreative && camera.position.y < -20) {
    killPlayer();
  }

  renderer.render(scene, camera);
}

animate();
</script>
</body>
</html>
