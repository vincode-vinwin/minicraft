const blockTypes = [
  {
    id: "grass",
    name: "Gras",
    inventoryTexture: textures.grassTop,
    materials: [
      new THREE.MeshStandardMaterial({ map: textures.dirt }),
      new THREE.MeshStandardMaterial({ map: textures.dirt }),
      new THREE.MeshStandardMaterial({ map: textures.grassTop }),
      new THREE.MeshStandardMaterial({ map: textures.dirt }),
      new THREE.MeshStandardMaterial({ map: textures.dirt }),
      new THREE.MeshStandardMaterial({ map: textures.dirt })
