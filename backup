<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="UTF-8">
  <title>Mini Minecraft JS</title>
  <style>
    :root {
      --hud-scale: min(1, 100vw / 900);
    }

    body {
      margin: 0;
      overflow: hidden;
      background: #87ceeb;
      font-family: "Trebuchet MS", sans-serif;
    }

    canvas {
      display: block;
    }

    #hud {
      position: fixed;
      inset: 0;
      pointer-events: none;
      z-index: 2;
    }

    #crosshair {
      position: fixed;
      top: 50%;
      left: 50%;
      width: 22px;
      height: 22px;
      transform: translate(-50%, -50%);
    }

    #crosshair::before,
    #crosshair::after {
      content: "";
      position: absolute;
      background: rgba(255, 255, 255, 0.95);
      box-shadow: 0 0 0 2px rgba(0, 0, 0, 0.35);
    }

    #crosshair::before {
      top: 0;
      left: 50%;
      width: 2px;
      height: 22px;
      transform: translateX(-50%);
    }

    #crosshair::after {
      top: 50%;
      left: 0;
      width: 22px;
      height: 2px;
      transform: translateY(-50%);
    }

    #hearts {
      position: fixed;
      left: 18px;
      top: 18px;
      display: grid;
      grid-template-columns: repeat(5, 26px);
      gap: 6px 8px;
      filter: drop-shadow(2px 2px 0 rgba(0, 0, 0, 0.55));
    }

    .heart {
      width: 26px;
      height: 24px;
      position: relative;
      image-rendering: pixelated;
    }

    .heart::before {
      content: "";
      position: absolute;
      inset: 0;
      background: #261015;
      clip-path: polygon(15% 0, 35% 0, 35% 10%, 50% 10%, 50% 0, 70% 0, 70% 10%, 85% 10%, 85% 30%, 75% 30%, 75% 50%, 65% 50%, 65% 60%, 55% 60%, 55% 70%, 45% 70%, 45% 60%, 35% 60%, 35% 50%, 25% 50%, 25% 30%, 15% 30%);
      transform: scale(1.16);
      transform-origin: center;
    }

    .heart::after {
      content: "";
      position: absolute;
      inset: 0;
      background: linear-gradient(180deg, #ff95ac 0 30%, #ff4f72 30% 58%, #d61a45 58% 100%);
      clip-path: polygon(15% 0, 35% 0, 35% 10%, 50% 10%, 50% 0, 70% 0, 70% 10%, 85% 10%, 85% 30%, 75% 30%, 75% 50%, 65% 50%, 65% 60%, 55% 60%, 55% 70%, 45% 70%, 45% 60%, 35% 60%, 35% 50%, 25% 50%, 25% 30%, 15% 30%);
    }

    .heart.empty::after {
      background: linear-gradient(180deg, #6c5a60 0 30%, #46353b 30% 58%, #2a1f24 58% 100%);
    }

    .heart.half::after {
      background:
        linear-gradient(90deg, transparent 50%, rgba(0, 0, 0, 0.55) 50% 54%, transparent 54%),
        linear-gradient(180deg, #ff95ac 0 30%, #ff4f72 30% 58%, #d61a45 58% 100%);
    }

    #inventory {
      position: fixed;
      left: 50%;
      bottom: 18px;
      transform: translateX(-50%);
      display: flex;
      gap: 8px;
      padding: 8px 10px;
      background: rgba(32, 24, 18, 0.55);
      border: 3px solid rgba(255, 255, 255, 0.18);
      border-radius: 8px;
      backdrop-filter: blur(4px);
    }

    .slot {
      width: 54px;
      height: 54px;
      border: 3px solid rgba(255, 255, 255, 0.25);
      background: rgba(0, 0, 0, 0.25);
      box-sizing: border-box;
      position: relative;
      image-rendering: pixelated;
    }

    .slot.active {
      border-color: #fff3b0;
      transform: translateY(-2px);
      box-shadow: 0 0 0 2px rgba(0, 0, 0, 0.28);
    }

    .slot img {
      width: 100%;
      height: 100%;
      display: block;
    }

    .slot span {
      position: absolute;
      left: 4px;
      top: 2px;
      color: white;
      font-size: 12px;
      font-weight: bold;
      text-shadow: 1px 1px 0 #000;
    }

    .slot .slot-count {
      left: auto;
      right: 4px;
      top: auto;
      bottom: 2px;
      font-size: 14px;
    }

    #selected-label {
      position: fixed;
      left: 50%;
      bottom: 92px;
      transform: translateX(-50%);
      color: white;
      font-weight: bold;
      text-shadow: 2px 2px 0 #000;
      letter-spacing: 0.04em;
    }

    #mode-label {
      position: fixed;
      right: 18px;
      top: 18px;
      color: white;
      font-weight: bold;
      text-shadow: 2px 2px 0 #000;
      letter-spacing: 0.04em;
    }

    #hand {
      position: fixed;
      right: 5vw;
      bottom: 2vh;
      width: calc(210px * var(--hud-scale));
      height: calc(210px * var(--hud-scale));
      transform-origin: 78% 100%;
      filter: drop-shadow(-16px 16px 12px rgba(0, 0, 0, 0.28));
      animation: hand-idle 1.8s steps(2, end) infinite;
    }

    #hand.swing {
      animation: swing 180ms steps(3, end);
    }

    #hand .forearm {
      position: absolute;
      right: 18px;
      bottom: 0;
      width: 94px;
      height: 138px;
      background:
        linear-gradient(#5b86d4 0 0) 0 0 / 100% 43% no-repeat,
        linear-gradient(#3d65b1 0 0) 0 43% / 100% 10% no-repeat,
        linear-gradient(#d7a37e 0 0) 0 53% / 100% 47% no-repeat;
      clip-path: polygon(22% 0, 100% 0, 100% 100%, 6% 100%, 6% 70%, 0 70%, 0 14%);
      image-rendering: pixelated;
      box-shadow:
        inset -12px 0 0 #c38f6b,
        inset 0 -12px 0 #c18c67,
        inset 0 0 0 4px rgba(0, 0, 0, 0.18);
    }

    #hand .forearm::before {
      content: "";
      position: absolute;
      right: 10px;
      top: 76px;
      width: 28px;
      height: 44px;
      background: #ebb58f;
      box-shadow:
        -22px 0 0 #dfab86,
        -44px 0 0 #d39b76,
        0 0 0 3px rgba(0, 0, 0, 0.12);
    }

    #hand .forearm::after {
      content: "";
      position: absolute;
      left: 16px;
      top: 54px;
      width: 78px;
      height: 10px;
      background: rgba(255, 255, 255, 0.14);
    }

    #hand .hand-top {
      position: absolute;
      right: 84px;
      bottom: 94px;
      width: 84px;
      height: 84px;
      background:
        linear-gradient(#efba93 0 0) 0 0 / 100% 100% no-repeat;
      box-shadow:
        inset -12px 0 0 #d39c77,
        inset 0 -10px 0 #cb936f,
        inset 0 0 0 4px rgba(0, 0, 0, 0.15);
    }

    #hand .thumb {
      position: absolute;
      right: 58px;
      bottom: 96px;
      width: 34px;
      height: 54px;
      background: #d7a17b;
      box-shadow:
        inset -8px 0 0 #c18a65,
        inset 0 -8px 0 #be8864,
        inset 0 0 0 3px rgba(0, 0, 0, 0.14);
    }

    @keyframes hand-idle {
      0% {
        transform: rotate(0deg) translate(0, 0);
      }
      50% {
        transform: rotate(1deg) translate(0, 3px);
      }
      100% {
        transform: rotate(0deg) translate(0, 0);
      }
    }

    @keyframes swing {
      0% {
        transform: rotate(0deg) translate(0, 0);
      }
      45% {
        transform: rotate(-24deg) translate(18px, 16px);
      }
      100% {
        transform: rotate(0deg) translate(0, 0);
      }
    }
  </style>
</head>
